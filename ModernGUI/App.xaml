<Application x:Class="CKAN.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark Theme (default) -->
            <SolidColorBrush x:Key="BackgroundPrimary" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="BackgroundSurface" Color="#252525"/>
            <SolidColorBrush x:Key="BackgroundElevated" Color="#2D2D2D"/>
            <SolidColorBrush x:Key="AccentPrimary" Color="#60CDFF"/>
            <SolidColorBrush x:Key="AccentSecondary" Color="#FFB347"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="Border" Color="#3D3D3D"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>